{
  "name": "termicolor",
  "compatibility_date": "2026-01-21",
  "assets": {
    "directory": "./dist"
  },
  // KV namespace for share tracking statistics
  // Create the namespace with: wrangler kv namespace create SHARE_STATS
  // Then update the id below with the returned namespace ID
  "kv_namespaces": [
    {
      "binding": "SHARE_STATS",
      "id": "REPLACE_WITH_KV_NAMESPACE_ID"
    }
  ]
}
